        <script>
        function launchReleases() {
            // 1. أصوات Sci-Fi سينمائية ناعمة
            try {
                const ctx = new (window.AudioContext || window.webkitAudioContext)();
                const master = ctx.createGain();
                master.gain.value = 0.12; // حجم منخفض وناعم
                master.connect(ctx.destination);

                // طبقة 1: نبضة عميقة ناعمة (مثل Iron Man HUD)
                function deepHum(freq, start, dur) {
                    const osc = ctx.createOscillator();
                    const gain = ctx.createGain();
                    const filter = ctx.createBiquadFilter();
                    filter.type = 'lowpass';
                    filter.frequency.value = 800;
                    osc.type = 'sine';
                    osc.frequency.setValueAtTime(freq, ctx.currentTime + start);
                    osc.frequency.linearRampToValueAtTime(freq * 1.2, ctx.currentTime + start + dur * 0.6);
                    osc.frequency.linearRampToValueAtTime(freq * 0.9, ctx.currentTime + start + dur);
                    gain.gain.setValueAtTime(0, ctx.currentTime + start);
                    gain.gain.linearRampToValueAtTime(1, ctx.currentTime + start + 0.05);
                    gain.gain.linearRampToValueAtTime(0.6, ctx.currentTime + start + dur * 0.5);
                    gain.gain.exponentialRampToValueAtTime(0.001, ctx.currentTime + start + dur);
                    osc.connect(filter); filter.connect(gain); gain.connect(master);
                    osc.start(ctx.currentTime + start);
                    osc.stop(ctx.currentTime + start + dur);
                }

                // طبقة 2: صوت تشغيل نظام ناعم (مثل Interstellar)
                function systemBoot(start) {
                    const osc = ctx.createOscillator();
                    const gain = ctx.createGain();
                    const filter = ctx.createBiquadFilter();
                    filter.type = 'bandpass';
                    filter.frequency.value = 600;
                    filter.Q.value = 2;
                    osc.type = 'triangle';
                    osc.frequency.setValueAtTime(180, ctx.currentTime + start);
                    osc.frequency.exponentialRampToValueAtTime(320, ctx.currentTime + start + 0.4);
                    osc.frequency.exponentialRampToValueAtTime(240, ctx.currentTime + start + 0.8);
                    gain.gain.setValueAtTime(0, ctx.currentTime + start);
                    gain.gain.linearRampToValueAtTime(1, ctx.currentTime + start + 0.08);
                    gain.gain.setValueAtTime(1, ctx.currentTime + start + 0.6);
                    gain.gain.exponentialRampToValueAtTime(0.001, ctx.currentTime + start + 1.2);
                    osc.connect(filter); filter.connect(gain); gain.connect(master);
                    osc.start(ctx.currentTime + start);
                    osc.stop(ctx.currentTime + start + 1.3);
                }

                // طبقة 3: نبضات خفيفة متتالية (data processing)
                function dataPulse(freq, start) {
                    const osc = ctx.createOscillator();
                    const gain = ctx.createGain();
                    osc.type = 'sine';
                    osc.frequency.value = freq;
                    gain.gain.setValueAtTime(0, ctx.currentTime + start);
                    gain.gain.linearRampToValueAtTime(0.8, ctx.currentTime + start + 0.02);
                    gain.gain.exponentialRampToValueAtTime(0.001, ctx.currentTime + start + 0.12);
                    osc.connect(gain); gain.connect(master);
                    osc.start(ctx.currentTime + start);
                    osc.stop(ctx.currentTime + start + 0.15);
                }

                // طبقة 4: طنين خلفي ناعم مستمر
                function ambientHum() {
                    const osc = ctx.createOscillator();
                    const gain = ctx.createGain();
                    const filter = ctx.createBiquadFilter();
                    filter.type = 'lowpass';
                    filter.frequency.value = 400;
                    osc.type = 'sawtooth';
                    osc.frequency.value = 60;
                    gain.gain.setValueAtTime(0, ctx.currentTime);
                    gain.gain.linearRampToValueAtTime(0.4, ctx.currentTime + 0.3);
                    gain.gain.setValueAtTime(0.4, ctx.currentTime + 1.5);
                    gain.gain.exponentialRampToValueAtTime(0.001, ctx.currentTime + 2.5);
                    osc.connect(filter); filter.connect(gain); gain.connect(master);
                    osc.start(ctx.currentTime);
                    osc.stop(ctx.currentTime + 2.6);
                }

                // تشغيل التسلسل الصوتي
                ambientHum();
                systemBoot(0.05);
                dataPulse(520, 0.1);
                dataPulse(680, 0.22);
                dataPulse(440, 0.34);
                dataPulse(760, 0.46);
                dataPulse(520, 0.58);
                deepHum(120, 0.6, 1.5);
                dataPulse(880, 0.9);
                dataPulse(660, 1.0);

            } catch(e) {}

            // 2. جسيمات الانطلاق
            const container = document.getElementById('launchParticles');
            for (let i = 0; i < 20; i++) {
                const p = document.createElement('div');
                p.className = 'particle';
                const angle = (Math.random() * 360) * Math.PI / 180;
                const dist = 80 + Math.random() * 120;
                p.style.setProperty('--tx', Math.cos(angle) * dist + 'px');
                p.style.setProperty('--ty', Math.sin(angle) * dist + 'px');
                p.style.animationDelay = Math.random() * 0.2 + 's';
                p.style.background = Math.random() > 0.5 ? '#00d4ff' : '#ffffff';
                container.appendChild(p);
                setTimeout(() => p.remove(), 1000);
            }

            // 3. تأثير الزر
            const btn = document.getElementById('releasesBtn');
            btn.style.transform = 'scale(0.95)';
            btn.style.boxShadow = '0 0 80px rgba(0,212,255,0.8)';
            setTimeout(() => { btn.style.transform = ''; }, 200);

            // 4. طبقة الانتقال مع تشويش الشاشة
            setTimeout(() => {
                const overlay = document.getElementById('launchOverlay');
                overlay.classList.add('active');

                // تشويش الشاشة في البداية
                const glitch = overlay.querySelector('.lo-glitch');
                glitch.style.display = 'block';
                setTimeout(() => {
                    glitch.style.animationDuration = '0.3s';
                }, 300);
                setTimeout(() => {
                    glitch.style.display = 'none';
                }, 800);

                // شريط التحميل
                const bar = document.getElementById('loBarFill');
                const percent = document.getElementById('loPercent');
                let prog = 0;

                // تأخير بسيط قبل بدء التحميل (تشويش أولاً)
                setTimeout(() => {
                    const interval = setInterval(() => {
                        // سرعة متغيرة مثل تحميل حقيقي
                        const speed = prog < 30 ? Math.random() * 12 + 5 :
                                      prog < 70 ? Math.random() * 6 + 2 :
                                      Math.random() * 4 + 1;
                        prog += speed;

                        // توقف مؤقت عشوائي مثل نظام حقيقي
                        if (prog >= 100) {
                            prog = 100;
                            clearInterval(interval);
                            // تشويش أخير قبل الانتقال
                            glitch.style.display = 'block';
                            setTimeout(() => {
                                window.location.href = 'releases.html';
                            }, 300);
                        }
                        bar.style.width = prog + '%';
                        percent.textContent = Math.floor(prog) + '%';
                    }, 60);
                }, 500);

            }, 350);
        }
