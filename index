    <script>
        // ===== STARS CANVAS =====
        const canvas = document.getElementById('starsCanvas');
        const ctx2 = canvas.getContext('2d');

        function resizeCanvas() {
            canvas.width = window.innerWidth;
            canvas.height = document.body.scrollHeight;
        }
        resizeCanvas();
        window.addEventListener('resize', resizeCanvas);

        const stars = [];
        const STAR_COUNT = 250;

        for (let i = 0; i < STAR_COUNT; i++) {
            stars.push({
                x: Math.random() * window.innerWidth,
                y: Math.random() * window.innerHeight * 4,
                r: Math.random() * 1.5 + 0.3,
                alpha: Math.random() * 0.8 + 0.2,
                speed: Math.random() * 0.3 + 0.05,
                twinkleSpeed: Math.random() * 0.02 + 0.005,
                twinkleDir: Math.random() > 0.5 ? 1 : -1,
                color: Math.random() > 0.85 ? '#ffd700' : Math.random() > 0.7 ? '#aaddff' : '#ffffff'
            });
        }

        function drawStars() {
            ctx2.clearRect(0, 0, canvas.width, canvas.height);
            stars.forEach(s => {
                s.alpha += s.twinkleSpeed * s.twinkleDir;
                if (s.alpha >= 1 || s.alpha <= 0.1) s.twinkleDir *= -1;
                ctx2.beginPath();
                ctx2.arc(s.x, s.y, s.r, 0, Math.PI * 2);
                ctx2.fillStyle = s.color;
                ctx2.globalAlpha = s.alpha;
                ctx2.fill();
                // بعض النجوم لها وميض
                if (s.r > 1.2) {
                    ctx2.beginPath();
                    ctx2.arc(s.x, s.y, s.r * 2.5, 0, Math.PI * 2);
                    ctx2.fillStyle = s.color;
                    ctx2.globalAlpha = s.alpha * 0.15;
                    ctx2.fill();
                }
            });
            ctx2.globalAlpha = 1;
            requestAnimationFrame(drawStars);
        }
        drawStars();

        // ===== SHOW BACK OVERLAY عند العودة من releases =====
        window.addEventListener('pageshow', function(e) {
            if (e.persisted || (window.performance && window.performance.navigation.type === 2)) {
                showBackOverlay();
            }
        });

        // كشف إذا جاء من releases.html
        if (document.referrer.includes('releases.html')) {
            showBackOverlay();
        }

        function showBackOverlay() {
            const overlay = document.getElementById('backOverlay');
            overlay.classList.add('active');
            const bar = document.getElementById('boBarFill');
            const percent = document.getElementById('boPercent');
            let prog = 0;
            const interval = setInterval(() => {
                prog += Math.random() * 10 + 4;
                if (prog >= 100) {
                    prog = 100;
                    clearInterval(interval);
                    setTimeout(() => { overlay.classList.remove('active'); }, 200);
                }
                bar.style.width = prog + '%';
                percent.textContent = Math.floor(prog) + '%';
            }, 50);
        }

        // ===== MENU =====
        function toggleMenu() {
            const nav = document.getElementById('navLinks');
            const hamburger = document.getElementById('hamburger');
            nav.classList.toggle('open');
            hamburger.classList.toggle('active');
        }
        function closeMenu() {
            const nav = document.getElementById('navLinks');
            const hamburger = document.getElementById('hamburger');
            nav.classList.remove('open');
            hamburger.classList.remove('active');
        }
    </script>
